# =============================================================================
# Vol Portfolio — Environment Configuration
# =============================================================================
# Copy this to .env and fill in your credentials:
#   cp .env.example .env
# =============================================================================

# IBKR Credentials
IBKR_USER=your_ibkr_username
IBKR_PASSWORD=your_ibkr_password
IBKR_TRADING_MODE=paper          # 'paper' or 'live'
IBKR_PORT=4002                   # 4002=paper, 4001=live

# TimescaleDB
TSDB_PASSWORD=vol_pass

# Logging
LOG_LEVEL=INFO
